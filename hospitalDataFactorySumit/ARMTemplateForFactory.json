												"userProperties": [],
												"typeProperties": {
													"source": {
														"type": "AzureSqlSource",
														"sqlReaderQuery": {
															"value": "@concat(\n    'SELECT COALESCE(CAST(MAX(loaddate) AS DATE), ''1990-01-01'') AS last_fetched_date\n    FROM dbo.logs\n    WHERE tablename = '\n    ,'''',\n    item().hosp_schema,\n    '.',\n    item().tablename,\n    ''''\n    )",
															"type": "Expression"
														},
														"queryTimeout": "02:00:00",
														"partitionOption": "None"
													},
													"dataset": {
														"referenceName": "ds_sql_db",
														"type": "DatasetReference",
														"parameters": {
															"ds_p_schema": "dbo",
