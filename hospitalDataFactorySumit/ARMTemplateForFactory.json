														"parameters": {
															"ds_p_schema": {
																"value": "@item().hosp_schema",
																"type": "Expression"
															},
															"ds_p_table": {
																"value": "@item().tablename",
																"type": "Expression"
															}
														}
													}
												],
												"outputs": [
													{
														"referenceName": "ds_adls_parquet",
														"type": "DatasetReference",
														"parameters": {
															"ds_p_folder_name": {
																"value": "@concat('EMR/',item().targetpath)",
																"type": "Expression"
															},
															"ds_p_filename": {
																"value": "@item().tablename",
																"type": "Expression"
															}
														}
													}
												]
											},
											{
												"name": "InsertLogs",
												"type": "SqlServerStoredProcedure",
												"dependsOn": [
													{
														"activity": "CopyFullLoad",
														"dependencyConditions": [
