													"type": "Expression"
												},
												"csvFile": {
													"value": "@concat(item(),'.csv')",
													"type": "Expression"
												}
											}
										}
									],
									"outputs": [
										{
											"referenceName": "ds_sql_db",
											"type": "DatasetReference",
											"parameters": {
												"ds_p_schema": {
													"value": "@pipeline().parameters.pp_hospital",
													"type": "Expression"
												},
												"ds_p_table": {
													"value": "@item()",
													"type": "Expression"
												}
											}
										}
									]
