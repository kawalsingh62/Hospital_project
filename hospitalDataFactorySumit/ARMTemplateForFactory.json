		{
			"name": "[concat(parameters('factoryName'), '/pl_csv_adls_to_sql')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "ForEachCSV",
						"type": "ForEach",
						"dependsOn": [],
