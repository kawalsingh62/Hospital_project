{
	"name": "pl_csv_adls_to_sql",
	"properties": {
		"activities": [
			{
				"name": "ForEachCSV",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@pipeline().parameters.CSV_Array",
						"type": "Expression"
					},
					"isSequential": true,
					"activities": [
						{
							"name": "csv_to_sql",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "DelimitedTextSource",
									"storeSettings": {
										"type": "AzureBlobFSReadSettings",
										"recursive": true,
										"enablePartitionDiscovery": false
									},
									"formatSettings": {
										"type": "DelimitedTextReadSettings"
									}
								},
								"sink": {
									"type": "AzureSqlSink",
									"writeBehavior": "insert",
									"sqlWriterUseTableLock": false
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_adls_csv",
									"type": "DatasetReference",
									"parameters": {
										"hospital": {
											"value": "@pipeline().parameters.pp_hospital",
											"type": "Expression"
										},
										"csvFile": {
											"value": "@concat(item(),'.csv')",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_sql_db",
									"type": "DatasetReference",
									"parameters": {
										"schema": {
											"value": "@pipeline().parameters.Schema",
											"type": "Expression"
										},
										"table": {
											"value": "@item()",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			}
		],
		"parameters": {
			"pp_hospital": {
				"type": "String",
				"defaultValue": "HospitalA"
			},
			"pp_csvFile": {
				"type": "string",
				"defaultValue": "ss"
			},
			"CSV_Array": {
				"type": "array",
				"defaultValue": [
					"departments",
					"encounters",
					"patients",
					"providers",
					"transactions"
				]
			},
			"Schema": {
				"type": "string",
				"defaultValue": "hospa"
			}
		},
		"annotations": [],
		"lastPublishTime": "2026-06-03T04:59:35Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}